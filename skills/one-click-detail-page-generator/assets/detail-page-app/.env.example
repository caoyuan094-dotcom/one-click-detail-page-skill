# Optional: Gemini analysis model via Yunwu OpenAI-compatible endpoint
YUNWU_GEMINI_MODEL=gemini-3.5-flash

# Optional: Google official Gemini endpoint fallback
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Optional: GPT Image2 compatible image API
# If you use yunwu.ai, set:
YUNWU_API_BASE=https://yunwu.ai/v1
YUNWU_API_KEY=
YUNWU_IMAGE_MODEL=gpt-image-2
# UI can also choose: gemini-3-pro-image-preview

# Or use OpenAI-compatible environment names:
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2

PORT=3042
